# ── Required ─────────────────────────────────────────────────────────────────
API_ID=12345678
API_HASH=your_api_hash_here
BOT_TOKEN=your_bot_token_here

# ── Spotify (optional, for Spotify link support) ──────────────────────────────
SPOTIFY_CLIENT_ID=your_spotify_client_id
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret

# ── YouTube cookies (optional, for age-restricted videos) ─────────────────────
# Export cookies from your browser using the "Get cookies.txt LOCALLY" extension
# YT_COOKIES_PATH=cookies.txt

# ── Quality settings ──────────────────────────────────────────────────────────
AUDIO_QUALITY=high          # low / medium / high
VIDEO_QUALITY=720           # 360 / 480 / 720 / 1080

# ── Downloads directory ───────────────────────────────────────────────────────
DOWNLOAD_DIR=./downloads
